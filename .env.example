EXA_API_KEY=
APIFY_API_TOKEN=
GITHUB_TOKEN=
VITE_API_BASE_URL=http://127.0.0.1:8010

# Preferred: comma-separated actor IDs/names for market validation.
APIFY_JOB_ACTOR_IDS=MXLpngmVpE8WTESQr,s3dtSTZSZWFtAVLn5,hKByXkMQaC5Qt9UMN

# Legacy single-actor fallback.
APIFY_JOB_ACTOR_ID=

# --- Schedule "Arrange my time" LLM refinement (optional) ---
# Any one configured key enables the hybrid scheduler/caption refinement.
# When none is set, the deterministic engine and template captions are used.
# Product default model is GPT 5.5 (OpenAI).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional override: openai | anthropic
LLM_PROVIDER=
# Optional model override; defaults to gpt-5.5 (openai)
LLM_MODEL=

# --- LinkedIn sharing ---
# Public base URL used to build shareable progress pages (for the LinkedIn unfurl).
APP_PUBLIC_BASE_URL=http://127.0.0.1:8010

# Phase-2 OAuth auto-publish (scaffold only; leave blank to use the no-OAuth share button).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
